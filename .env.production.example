# Production Environment Variables
# Copy this file to .env.local for local development
# or set these as secrets in your cloud provider.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/linguadapt?schema=public"

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
# Obtain from https://dashboard.stripe.com/webhooks (after creating the endpoint)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Application ──────────────────────────────────────────────────────────────
# The public-facing URL of this deployment (no trailing slash)
APP_URL="https://your-domain.com"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (APP_URL is automatically included).
# Leave empty for API-only (no cross-origin browsers) deployments.
CORS_ORIGINS=""

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Required in production — generate with: openssl rand -base64 48
# Server will refuse to start in production if these are missing or weak.
JWT_SECRET=""
REFRESH_SECRET=""

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Required to enable Google Sign-In. Obtain from https://console.cloud.google.com/
# Credentials > OAuth 2.0 Client IDs > Web application
GOOGLE_CLIENT_ID=""

# ─── Observability ───────────────────────────────────────────────────────────
# Logger verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
# Sentry DSN (leave empty to disable). https://sentry.io > Project Settings > Client Keys
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"
# Release identifier (git SHA or semver) — helps Sentry group errors
SENTRY_RELEASE=""

# Optional: Firebase config for client-side auth (if Firebase auth is enabled)
# FIREBASE_API_KEY=""
# FIREBASE_AUTH_DOMAIN=""
# FIREBASE_PROJECT_ID=""
# FIREBASE_STORAGE_BUCKET=""
# FIREBASE_MESSAGING_SENDER_ID=""
# FIREBASE_APP_ID=""
