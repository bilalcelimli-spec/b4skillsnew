{
  "name": "b4skills",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade, CEFR-aligned adaptive English proficiency testing platform with AI-assisted scoring, multi-tenant B2B support, and proctoring.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --platform=node --format=esm --outfile=dist/server.js --bundle --packages=external",
    "build": "npm run build:client && npm run build:server && npx prisma generate",
    "start": "NODE_ENV=production node dist/server.js",
    "start:prod": "npx prisma migrate deploy && NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:delete-all-items": "tsx scripts/delete-all-items.ts",
    "db:purge": "tsx scripts/purge-platform-data.ts",
    "db:seed:grammar-300": "tsx scripts/seed-grammar-300-sota.ts",
    "db:seed:vocab-200": "tsx scripts/seed-vocab-200-sota.ts",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "quality:vocab": "tsx scripts/validate-vocab-200-quality.ts",
    "db:job:calibrate-pretest": "tsx scripts/jobs/auto-calibrate-pretest.ts",
    "db:job:retire-items": "tsx scripts/jobs/item-retirement-job.ts",
    "db:job:detect-dif": "tsx scripts/jobs/dif-detection-job.ts"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "google-tts-api": "^2.0.2",
    "gtts": "^0.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.8.3",
    "recharts": "^3.8.1",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
