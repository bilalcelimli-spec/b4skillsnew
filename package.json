{
  "name": "b4skills",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade, CEFR-aligned adaptive English proficiency testing platform with AI-assisted scoring, multi-tenant B2B support, and proctoring.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --platform=node --format=esm --outfile=dist/server.js --bundle --packages=external",
    "build": "npm run build:client && npm run build:server && npx prisma generate",
    "build:all": "npm run build",
    "start": "NODE_ENV=production node dist/server.js",
    "start:prod": "npx prisma migrate deploy && NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "lighthouse": "lhci autorun",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run test/load/exam-session.js",
    "test:mutation": "stryker run",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:delete-all-items": "tsx scripts/delete-all-items.ts",
    "db:purge": "tsx scripts/purge-platform-data.ts",
    "db:seed:grammar-300": "tsx scripts/seed-grammar-300-sota.ts",
    "db:seed:vocab-200": "tsx scripts/seed-vocab-200-sota.ts",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "quality:vocab": "tsx scripts/validate-vocab-200-quality.ts",
    "validate:items": "tsx scripts/validate-items.ts",
    "validate:items:strict": "tsx scripts/validate-items.ts --strict",
    "validate:seeds": "tsx scripts/validate-seeds.ts",
    "validate:seeds:strict": "tsx scripts/validate-seeds.ts --strict",
    "verify:coverage": "tsx scripts/verify-skill-coverage.ts",
    "verify:irt": "tsx scripts/verify-irt-health.ts",
    "backfill:irt-priors": "tsx scripts/backfill-irt-priors.ts",
    "db:job:calibrate-pretest": "tsx scripts/jobs/auto-calibrate-pretest.ts",
    "db:job:retire-items": "tsx scripts/jobs/item-retirement-job.ts",
    "db:job:detect-dif": "tsx scripts/jobs/dif-detection-job.ts",
    "iqs:batch": "tsx scripts/iqs-batch-run.ts",
    "iqs:batch:all": "tsx scripts/iqs-batch-run.ts --all",
    "db:seed:anchors": "tsx scripts/seed-anchor-items.ts",
    "db:seed:anchors:dry": "tsx scripts/seed-anchor-items.ts --dry-run",
    "db:seed:diverse-types": "tsx scripts/seed-diverse-item-types.ts",
    "db:seed:diverse-types:dry": "tsx scripts/seed-diverse-item-types.ts --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@aws-sdk/client-s3": "^3.817.0",
