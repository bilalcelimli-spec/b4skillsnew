# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── Application ──────────────────────────────────────────────────────────────
APP_URL="http://localhost:3001"

# ─── Social SSO ──────────────────────────────────────────────────────────────
# Google OAuth2 — https://console.cloud.google.com/apis/credentials
# Add http://localhost:3001/api/auth/social/google/callback as Authorised redirect URI
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/social/google/callback"

# Microsoft (Entra ID) — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Add http://localhost:3001/api/auth/social/microsoft/callback as redirect URI
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3001/api/auth/social/microsoft/callback"

# LinkedIn — https://www.linkedin.com/developers/apps
# Add http://localhost:3001/api/auth/social/linkedin/callback as redirect URI
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3001/api/auth/social/linkedin/callback"

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL="debug"
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"

# OpenTelemetry — set OTLP_ENDPOINT to enable traces + metrics export
# e.g. http://localhost:4318 for a local Grafana Alloy / OTel Collector
# Leave empty to disable OTel (Sentry still captures errors)
OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="linguadapt"
