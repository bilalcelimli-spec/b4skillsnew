// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE IDENTITY & TENANCY ---

model Organization {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Branding & Config
  branding      Json?     // { logoUrl, primaryColor, customCss, faviconUrl, portalName }
  settings      Json?     // { allowedDomains, sessionTimeout, securityLevel, apiKey, webhookUrl }
  ssoConfig     Json?     // { provider: 'SAML' | 'OIDC', entryPoint, issuer, cert, clientId, clientSecret, enabled }
  apiKeyDigest  String?   // SHA-256 digest of the org's Score Reporting API key
  
  // Relations
  users         User[]
  items         Item[]    // Tenant-specific items (optional)
  sessions      Session[]
  cohorts       Cohort[]
  licenses      License[]
  transactions  PaymentTransaction[]
  auditLogs     AuditLog[]
  webhooks      Webhook[]
  apiKeys       ApiKey[]
  feedbacks     Feedback[]
  examCodes     ExamCode[]
}

model ExamCode {
  id             String       @id @default(cuid())
  code           String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  productLine    String       // e.g., "Primary (7-10)", "Corporate", etc.
  isUsed         Boolean      @default(false)
  usedByEmail    String?
  usedAt         DateTime?
  
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
}

model Feedback {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  sessionId      String       @unique
  session        Session      @relation(fields: [sessionId], references: [id])
  rating         Int          // 1-5
  comment        String?
  category       String?      // e.g., "UI", "CONTENT", "TECHNICAL"
}

model AuditLog {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  
  action         String       // e.g., "BRANDING_UPDATE", "CANDIDATE_IMPORT"
  entityType     String       // e.g., "Organization", "Candidate"
  entityId       String
  
  previousData   Json?
  newData        Json?
  details        Json?        // Contextual data about the change
  ipAddress      String?

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model Webhook {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  url            String
  secret         String       // For signature verification
  events         String[]     // e.g., ["session.completed", "proctoring.alert"]
  isActive       Boolean      @default(true)
}

model ApiKey {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  key            String       @unique // Hashed key
  lastUsed       DateTime?
  isActive       Boolean      @default(true)
}

model PaymentTransaction {
  id              String    @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  
  amount          Int       // In cents
  currency        String    @default("USD")
  status          String    // PENDING, COMPLETED, FAILED
  stripeSessionId String?   @unique
  creditsAdded    Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  role            UserRole  @default(CANDIDATE)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  
  // Auth
  password        String?
  emailVerified   DateTime?
  image           String?
  refreshToken         String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  verifyEmailToken     String?

  // Social SSO
  oauthProvider   String?   // "google" | "microsoft" | "linkedin"
  oauthProviderId String?   // provider subject (sub)

  // Two-Factor Authentication (TOTP)
  twoFactorSecret  String?   // encrypted base32 TOTP secret
  twoFactorEnabled Boolean   @default(false)
  
  // Relations
  sessions        Session[]
  raterTasks      RatingTask[] @relation("RaterTasks")
  candidateProfile CandidateProfile?
  auditLogs       AuditLog[]
  transactions    PaymentTransaction[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
}

enum UserRole {
  SUPER_ADMIN
  ASSESSMENT_DIRECTOR
  CONTENT_ADMIN
  INST_ADMIN
  TEACHER
  RATER
  PROCTOR
  CANDIDATE
}

model CandidateProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])

  // Demographics (Phase 3)
  nativeLanguage String?   // ISO 639-1: "es", "fr", "ar", "en", etc.
  gender        String?   // "M" | "F" | "Other" | "Prefer not to say"
  ageGroup      String?   // "13-17" | "18-25" | "26-35" | "36-50" | "50+"
  educationLevel String?  // "Secondary" | "Undergraduate" | "Graduate"

  dateOfBirth   DateTime?
  metadata      Json?     // { targetScore, etc }
}

// --- ITEM BANK ---

model Item {
  id              String    @id @default(cuid())
  itemCode        String?   @unique // Human-readable code e.g. VOC-B1-0042
  organizationId  String?   // Null means global/system item
  organization    Organization? @relation(fields: [organizationId], references: [id])
  
  type            ItemType
  skill           SkillType
  cefrLevel       CefrLevel
  
  // Psychometric Parameters (IRT 3PL Model)
  difficulty      Float     @default(0.0) // b-parameter
  discrimination  Float     @default(1.0) // a-parameter
  guessing        Float     @default(0.0) // c-parameter
  
  // Content
  content         Json      // { prompt, options, correctAnswer, rubric, etc }
  assets          Asset[]
  
  // Metadata
  tags            String[]
  status          ItemStatus @default(DRAFT)
  isPretest       Boolean    @default(false)
  version         Int        @default(1)
  metadata        Json?      // Pipeline state, QA scores, audit trail
  
  // ── FAZ 1: Anchor Item & IQS ─────────────────────────────────────────────
  // isAnchor: true → item must appear in every test form for equating (Kolen & Brennan 2014)
  // Target pool: 6 skill × 7 CEFR × 10 = 420 anchor items
  isAnchor        Boolean   @default(false)
  // iqScore: Item Quality Score (0–100). IQS ≥ 80 → REVIEW, ≥ 90 → ACTIVE, < 60 → REJECT
  iqScore         Float?

  // ── FAZ 1: Three-Axis CEFR Classification (Blueprint §6.3) ───────────────
  // cefrLevel is kept for backward-compat (overall). The three axes below enable
  // construct-specific calibration (Cambridge English Profile / CEFR Companion Volume 2020).
  cefrLinguisticRange    CefrLevel? // Axis 1: Vocabulary + Grammar range
  cefrLinguisticAccuracy CefrLevel? // Axis 2: Error tolerance / accuracy
  cefrFunctionalAdequacy CefrLevel? // Axis 3: Task completion / functional adequacy
  // Audit trail: { ai: "B2", expert1: "B2", expert2: "B1", empirical: "B2" }
  cefrSources     Json?

  // Stats
  exposureCount   Int       @default(0)
  pVal            Float?    // Classical test theory difficulty

  // Item Retirement (Phase 3)
  difStatus       String?   // CLEAR | FLAGGED | MONITORING
  latestDifReviewAt DateTime?

  retirementReason     String?   // "Low discrimination" | "Poor fit" | "Too easy/hard" | "Negative correlation"
  retiredAt            DateTime?
  retiredBy            String?   // User.id
  retirementScore      Float?    // Latest retirement score (0-1)
  retirementScoreHistory Json?   // Array of { score, computedAt }
  canBeReactivated     Boolean   @default(true)

  responses       Response[]
  retirementAuditLogs RetirementAuditLog[]
  difReports      DifReportArchive[]
  difFlaggedItem  DifFlaggedItem?
  calibrationRuns CalibrationRun[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([skill, cefrLevel])
  @@index([skill, cefrLevel, status])  // Critical composite for CAT item selection query
  @@index([status, skill])
  @@index([organizationId, status])
  @@index([status, retirementScore])  // For retirement monitoring queries
  @@index([isAnchor, skill, cefrLevel])  // Faz1: anchor item queries for equating
  @@index([iqScore])                     // Faz1: quality gate queries
}

model RetirementAuditLog {
  id              String    @id @default(cuid())
  itemId          String
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  action          String    // FLAGGED_FOR_REVIEW | AUTO_RETIRED | MANUAL_RETIRED | REACTIVATED | REJECTED
  score           Float?    // Retirement score at time of action
  reason          String?   // Explanation of why this action was taken

  triggeredBy     String?   // BATCH_JOB | User.id
  approvalStatus  String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  approvedBy      String?   // User.id who approved/rejected
  approvalDate    DateTime?
  notes           String?   // Additional notes from approver

  createdAt       DateTime  @default(now())

  @@index([itemId])
  @@index([action])
  @@index([approvalStatus, createdAt])
}

model DifReportArchive {
  id              String    @id @default(cuid())
  itemId          String
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  runDate         DateTime  @default(now())
  groupVariable   String    // "gender" | "nativeLanguage" | "ageGroup"
  referenceGroup  String
  focalGroup      String

  // Mantel-Haenszel statistics
  mhOddsRatio     Float?
  mhDelta         Float     // Log odds ratio
  chiSquared      Float?
  pValue          Float?

  // ETS Classification
  classification  String    // "A" | "B" | "C"
  referenceN      Int
  focalN          Int

  // Logistic regression
  logisticUniformDif     Float?
  logisticNonUniformDif  Float?

  // Review status
  isReviewed      Boolean   @default(false)
  reviewedBy      String?   // User.id
  reviewedAt      DateTime?
  reviewNotes     String?

  @@index([itemId])
  @@index([classification, runDate])
  @@index([isReviewed])
}

model DifFlaggedItem {
  id              String    @id @default(cuid())
  itemId          String    @unique
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  flaggedAt       DateTime  @default(now())
  worstClassification String // "A" | "B" | "C"
  totalDifResults Int       // Count of B/C classifications across all groups
  status          String    @default("PENDING") // PENDING | IN_REVIEW | REMEDIATED | RETIRED
  notes           String?

  @@index([status, flaggedAt])
}

enum ItemType {
  MULTIPLE_CHOICE
  FILL_IN_BLANKS
  DRAG_DROP
  SPEAKING_PROMPT
  WRITING_PROMPT
  INTEGRATED_TASK
}

enum SkillType {
  READING
  LISTENING
  WRITING
  SPEAKING
  GRAMMAR
  VOCABULARY
}

enum CefrLevel {
  PRE_A1
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ItemStatus {
  DRAFT
  REVIEW
  ACTIVE
  PRETEST
  RETIRED
}

model Asset {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  type      String   // IMAGE, AUDIO, VIDEO
  url       String
  metadata  Json?
}

// --- SESSION & RESPONSES ---

model Session {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  candidateId     String
  candidate       User      @relation(fields: [candidateId], references: [id])
  
  status          SessionStatus @default(SCHEDULED)
  
  // Adaptive State
  theta           Float     @default(0.0) // Current ability estimate
  sem             Float     @default(1.0) // Standard Error of Measurement
  currentTheta    Float?    // For real-time insights
  
  // Progress
  currentStage    Int       @default(1)
  responsesCount  Int       @default(0)
  cefrLevel       CefrLevel?
  metadata        Json?     // { browserInfo, ipAddress, deviceFingerprint }
  
  responses       Response[]
  proctoringEvents ProctoringEvent[]
  scoreReport     ScoreReport?
  feedback        Feedback?
  
  startedAt       DateTime?
  completedAt     DateTime?
  validUntil      DateTime? // 2-year validity policy: set to completedAt + 2 years on completion
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId, candidateId])
  @@index([validUntil])  // for expiry queries
  @@index([organizationId, status])
  @@index([candidateId, status])
  @@index([status])
  @@index([createdAt])
  @@index([status, updatedAt])       // SLO monitor: rolling-window IN_PROGRESS/COMPLETED lookups
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  SCORING
  COMPLETED
  FLAGGED
  EXPIRED
}

model Response {
  id              String    @id @default(cuid())
  sessionId       String
  session         Session   @relation(fields: [sessionId], references: [id])
  itemId          String
  item            Item      @relation(fields: [itemId], references: [id])
  
  value           String?   // The actual answer (serialized JSON or string)
  artifactUrl     String?   // S3 URL for audio/writing
  
  // Scoring
  isCorrect       Boolean?
  score           Float?    // 0.0 to 1.0
  isPretest       Boolean   @default(false)
  aiScore         Float?
  humanScore      Float?
  
  // Metadata
  latencyMs       Int       @default(0)
  rtZScore        Float?    // Standardised response time z-score (van der Linden RT-IRT model)
  rtFlag          String?   // RAPID_GUESS | SOLUTION_BEHAVIOR | NORMAL
  adjustedScore   Float?    // Score after response-time penalty (used for theta estimation)
  order           Int       // Sequence in the test
  metadata        Json?     // { confidence, flags, aiFeedback, proctoringEvents, calibrationData, etc }
  
  ratingTask      RatingTask?
  
  createdAt       DateTime  @default(now())

  @@index([sessionId])
  @@index([itemId])
  @@index([sessionId, order])
  @@index([sessionId, isPretest])    // submitResponse: resolves usedItemIds filtered by isPretest
  @@index([createdAt])               // SLO monitor: rolling-window session counts
}

model RatingTask {
  id              String    @id @default(cuid())
  responseId      String    @unique
  response        Response  @relation(fields: [responseId], references: [id])
  
  status          RatingStatus @default(PENDING)
  raterId         String?
  rater           User?     @relation("RaterTasks", fields: [raterId], references: [id])
  
  score           Float?
  feedback        String?

  // Double-blind second rater (IRR)
  secondRaterId   String?
  secondRaterScore Float?
  secondRaterFeedback String?
  /** Quadratic Weighted Kappa between first and second rater (0–1). */
  qwk             Float?
  /** True when |score - secondRaterScore| > 0.20, requiring a third arbitration rater. */
  requiresArbitration Boolean @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([raterId])
  @@index([requiresArbitration])
}

enum RatingStatus {
  PENDING
  CLAIMED
  COMPLETED
  FLAGGED
}

// --- SCORING & ANALYTICS ---

model ScoreReport {
  id              String    @id @default(cuid())
  sessionId       String    @unique
  session         Session   @relation(fields: [sessionId], references: [id])
  
  overallCefr     CefrLevel
  overallScore    Int       // Scaled score (e.g., 0-100)
  
  // Skill breakdowns
  readingScore    Int?
  listeningScore  Int?
  writingScore    Int?
  speakingScore   Int?
  grammarScore    Int?
  vocabularyScore Int?
  
  /** Full diagnostic report: skill CIs, Can-Do statements, MIRT vector, etc. */
  diagnosticReport Json?
  
  isVerified      Boolean   @default(false)
  certificateUrl  String?
  
  createdAt       DateTime  @default(now())
}

model ProctoringEvent {
  id              String    @id @default(cuid())
  sessionId       String
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type            String    // TAB_SWITCH, FACE_LOST, NOISE_DETECTED, etc.
  severity        Int       // 1 (Low) to 5 (Critical)
  timestamp       DateTime  @default(now())
  metadata        Json?

  @@index([sessionId])
  @@index([sessionId, severity])
}

// --- SYSTEM ---

model SystemConfig {
  id        String   @id @default("global")
  config    Json     // { cefrThresholds: { A1: -2.5, ... }, adaptiveSettings: { ... } }
  updatedAt DateTime @updatedAt
}

// ─── CALIBRATION PIPELINE ──────────────────────────────────────────────────────
//
// CalibrationRun: Stores the result of one EM cycle for a pretest item.
// Produced by the online calibration job (scheduled-jobs.ts → runPretestCalibration).
//
// Lifecycle:
//   PRETEST  → (n≥200) → CalibrationRun recorded, item stays PRETEST
//   PRETEST  → (n≥500 & stable & |Δb|≤0.30) → item promoted to ACTIVE
//   ACTIVE   → parameter drift > 0.50 logit → CalibrationRun flagged, item → REVIEW
//
// Reference: Stocking (1990), van der Linden & Hambleton (1997) ch. 18

model CalibrationRun {
  id              String    @id @default(cuid())
  itemId          String
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // EM iteration context
  runAt           DateTime  @default(now())
  triggerSource   String    @default("SCHEDULED")  // SCHEDULED | MANUAL | API

  // Sample size
  nResponses      Int       // total responses used in this EM cycle
  nPretest        Int       // subset that were flagged isPretest=true

  // Previous parameters (before update)
  prevA           Float?
  prevB           Float?
  prevC           Float?

  // Estimated parameters (after EM update)
  aEstimate       Float
  bEstimate       Float
  cEstimate       Float

  // Standard errors (from inverse Fisher information approximation)
  aSE             Float?
  bSE             Float?
  cSE             Float?

  // Convergence diagnostics
  deltaB          Float     // |bNew - bOld|
  deltaA          Float     // |aNew - aOld|
  logLikelihood   Float?    // Marginal LL after update

  // Stability gate outcome
  stable          Boolean   // true = passed all gates; false = rejected
  rejectionReason String?   // populated when !stable

  // Promotion action taken after this run
  promotedToActive Boolean  @default(false)
  promotedAt      DateTime?

  @@index([itemId, runAt])
  @@index([stable, runAt])
  @@index([promotedToActive])
}

// ─── AI SCORER INTER-RATER RELIABILITY ────────────────────────────────────────
//
// AnchorRating: A human-expert rating of an anchor writing/speaking response.
// Used to compute Quadratic Weighted Kappa (QWK) between the AI scorer and human.
// Target: QWK ≥ 0.80 (ETS standard for high-stakes AI scoring).

model AnchorRating {
  id            String    @id @default(cuid())
  skill         String    // WRITING | SPEAKING
  cefrLevel     String    // A1 … C2
  responseText  String?   // Anonymised written response (or transcript)
  artifactUrl   String?   // S3 URL for audio (SPEAKING)

  // Expert human scores (0.0 – 1.0 on each dimension)
  humanScore        Float    // Holistic 0–1
  humanScoreDim1    Float?   // e.g. Task Achievement
  humanScoreDim2    Float?   // Coherence & Cohesion
  humanScoreDim3    Float?   // Lexical Resource
  humanScoreDim4    Float?   // Grammatical Range & Accuracy
  humanScoreDim5    Float?   // Pronunciation / Fluency (SPEAKING)

  expertId      String    // User.id of human rater
  ratedAt       DateTime  @default(now())

  // AI scorer results (populated after running /api/psychometrics/irr/evaluate)
  aiScore           Float?
  aiScoreDim1       Float?
  aiScoreDim2       Float?
  aiScoreDim3       Float?
  aiScoreDim4       Float?
  aiScoreDim5       Float?
  aiEvaluatedAt     DateTime?

  // Agreement metrics
  qwk             Float?    // Quadratic Weighted Kappa (human vs AI, holistic)
  absoluteDiff    Float?    // |humanScore - aiScore|
  passesFloor     Boolean?  // qwk ≥ 0.80

  @@index([skill, cefrLevel])
  @@index([passesFloor])
}

// ─── CONCURRENT VALIDITY STUDY ────────────────────────────────────────────────
//
// Stores paired scores from a concurrent validity study:
//   b4skills θ / CEFR band + external test score (Linguaskill, IELTS, etc.)
// Target: Pearson r ≥ 0.80, CEFR agreement ≥ 85%

model ConcurrentValidityRecord {
  id                  String    @id @default(cuid())
  studyName           String    // e.g. "Linguaskill Pilot — May 2026"
  recordedAt          DateTime  @default(now())

  // b4skills results
  b4sThetaOverall     Float
  b4sCefrLevel        String    // e.g. "B2"
  b4sScaledScore      Int?      // 0-100

  // External test
  externalTestName    String    // "Linguaskill" | "IELTS" | "TOEFL iBT"
  externalScore       Float     // Raw score from external test
  externalCefrLevel   String?   // CEFR mapping reported by external test

  // Agreement
  cefrAgreement       Boolean?  // b4sCefrLevel == externalCefrLevel
  cefrWithinOneBand   Boolean?  // |band_diff| ≤ 1

  candidateId         String?   // Anonymised — no direct PII link required
  demographicGroup    String?   // Optional grouping label (age, L1, etc.)

  @@index([studyName])
  @@index([b4sCefrLevel])
}


model Cohort {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String
  description     String?
  
  createdAt       DateTime  @default(now())
}

model License {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  type            String    // ENTERPRISE, TRIAL, etc.
  credits         Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}
